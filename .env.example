# Token du bot Discord (https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Client ID de ton application Discord
CLIENT_ID=your_discord_client_id_here

# (Optionnel) Guild ID pour deployer les commandes sur un seul serveur (plus rapide en dev)
GUILD_ID=

# Cle API HenrikDev (optionnelle, mais recommandee pour eviter le rate limit)
# Demande ta cle sur: https://docs.henrikdev.xyz/
HENRIK_API_KEY=

# Si "true", redeploie les slash commands a chaque demarrage du bot (pratique sur Railway)
DEPLOY_COMMANDS_ON_START=false

# Dossier de stockage des comptes lies. Sur Railway, monte un volume et mets
# son chemin ici (ou utilise RAILWAY_VOLUME_MOUNT_PATH qui est detecte auto).
DATA_DIR=

# ID du salon textuel Discord ou le classement s'affichera (auto-update)
LEADERBOARD_CHANNEL_ID=

# Intervalle de rafraichissement du classement en minutes (defaut: 15)
LEADERBOARD_UPDATE_MINUTES=15
